{
  "name": "@grace/sdk",
  "version": "0.0.0-s11",
  "description": "Facade-first Grace TypeScript Node SDK package harness.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "graceProtocol": {
    "tier": 3,
    "protocolVersion": "grace-protocol-v1",
    "vectorSuite": "grace-protocol-v1",
    "supportedVectors": [
      "content-addresses.v1.json",
      "manifest-validation.v1.json",
      "eligibility.v1.json"
    ],
    "tier4LocalIntegration": {
      "capabilities": [
        "facade-transfer-progress-diagnostics"
      ],
      "nonClaims": [
        "manifest-upload",
        "contentblock-transfer",
        "direct-storage-deduplication",
        "resumable-upload-download",
        "offline-watch"
      ]
    },
    "runtimeBoundary": "native-typescript-node-no-dotnet-runtime"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smoke": "npm run build && node smoke/import-facade.mjs",
    "test": "npm run build && node --test test/*.mjs"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
